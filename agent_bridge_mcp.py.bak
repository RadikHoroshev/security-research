#!/usr/bin/env python3
"""
agent_bridge_mcp.py — Единый мост мульти-агентной системы

Goose Hub ↔ Агенты ↔ Знания ↔ Fallback

Архитектура:
  ┌─ Goose (Hub) ─┐
  │   qwen3.5     │
  └───┬─────┬─────┘
      │     │
  ┌───▼─────▼─────┐
  │  Agent Bridge  │ ← Ты здесь
  │  Router + Hub  │
  └──┬──┬──┬──┬───┘
     │  │  │  │
  ┌──▼┐┌▼──▼┐┌▼──┐┌▼─────┐
  │Qw ││Gem  ││Jul││Codex │
  │en ││ini  ││es ││/Claude│
  └───┘└─────┘└───┘└──────┘

Модель маршрутизации:
  1. Сначала локальные агенты (бесплатно, без лимитов)
  2. При исчерпании — облачные
  3. При исчерпании облачных — другие локальные
  4. On-demand — Claude Desktop, Qwen Desktop
"""

import json
import os
import shutil
import subprocess
from datetime import datetime
from pathlib import Path

