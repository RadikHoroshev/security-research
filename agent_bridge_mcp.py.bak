# ═══════════════════════════════════════════════════════════
# FALLBACK MANAGER — Когда лимиты исчерпаны
# ═══════════════════════════════════════════════════════════

@mcp.tool()
def fallback_chain(task_type: str, prompt: str) -> dict:
    """
    Запустить fallback chain когда агенты исчерпали лимиты.

    Автоматически перебирает ВСЕ доступные агенты по порядку:
      1. Ollama локальные (всегда доступны)
      2. Qwen CLI
      3. Gemini CLI
      4. Codex CLI
      5. Jules async

    Возвращает первый успешный результат.
    """
    health = agent_health()

    # Определяем порядок fallback
    if task_type == "coding":
        chain = [
            ("ollama", "qwen2.5-coder:14b", ollama_run, prompt, "qwen2.5-coder:14b"),
            ("ollama", "qwen2.5-coder:7b", ollama_run, prompt, "qwen2.5-coder:7b"),
            ("qwen_cli", None, qwen_run, prompt, None),
            ("gemini_cli", None, gemini_run, prompt, None),
        ]
    elif task_type == "reasoning":
        chain = [
            ("ollama", "deepseek-r1:8b", ollama_run, prompt, "deepseek-r1:8b"),
            ("qwen_cli", None, qwen_run, prompt, None),
            ("gemini_cli", None, gemini_run, prompt, None),
        ]
    elif task_type == "heavy":
        chain = [
            ("qwen_cli", None, qwen_run, prompt, None),
            ("ollama", "qwen2.5-coder:14b", ollama_run, prompt, "qwen2.5-coder:14b"),
            ("jules", None, jules_create_task, prompt, None),
        ]
    else:
        chain = [
            ("ollama", "gemma4:latest", ollama_run, prompt, "gemma4:latest"),
            ("ollama", "qwen2.5-coder:7b", ollama_run, prompt, "qwen2.5-coder:7b"),
            ("gemini_cli", None, gemini_run, prompt, None),
        ]

    for agent_key, model_name, func, arg, extra in chain:
        agent_status = health.get(agent_key, {}).get("status", "unknown")

        if agent_key == "ollama":
            if agent_status == "online" and model_name in health["ollama"].get("models", []):
                try:
                    result = func(arg, model_name)
                    return {
                        "agent": agent_key,
                        "model": model_name,
                        "status": "success",
                        "result": result,
                    }
                except Exception as e:
                    continue

        elif agent_status == "online":
            try:
                result = func(arg)
                return {
                    "agent": agent_key,
                    "model": model_name or "default",
                    "status": "success",
                    "result": result,
                }
            except Exception as e:
                continue

    return {
        "status": "all_exhausted",
        "error": "Все агенты исчерпали лимиты или недоступны",
        "recommendation": "Попробуйте позже или используйте Jules для async",
    }


# ═══════════════════════════════════════════════════════════
# OBSIDIAN — База знаний
# ═══════════════════════════════════════════════════════════

@mcp.tool()
def obsidian_search(query: str, max_results: int = 5) -> list:
    """Поиск в Obsidian Vault по заголовкам и содержимому заметок."""
    results = []
    if not os.path.isdir(VAULT_DIR):
        return [{"error": "Obsidian Vault не найден"}]

    try:
        # Поиск через grep по markdown файлам
        cmd = ["grep", "-rl", "-i", query, VAULT_DIR, "--include=*.md"]
        r = subprocess.run(cmd, capture_output=True, text=True, timeout=10)
        files = r.stdout.strip().split("\n") if r.stdout.strip() else []

        for f in files[:max_results]:
            if f and os.path.exists(f):
                with open(f, "r") as fh:
                    content = fh.read(2000)  # Первые 2000 символов
                results.append({
                    "file": os.path.relpath(f, VAULT_DIR),
                    "preview": content[:500],
                })
    except Exception as e:
        results = [{"error": str(e)}]

    return results


@mcp.tool()
def obsidian_read(note: str) -> str:
    """Прочитать заметку из Obsidian Vault по имени или пути."""
    if not os.path.isdir(VAULT_DIR):
        return "Obsidian Vault не найден"

    # Пробуем разные варианты
    candidates = [
        os.path.join(VAULT_DIR, note),
        os.path.join(VAULT_DIR, note + ".md"),
    ]

    for path in candidates:
        if os.path.isfile(path):
            with open(path, "r") as f:
                return f.read()

    return f"Заметка '{note}' не найдена. Доступные категории: проверьте через obsidian_list"


@mcp.tool()
def obsidian_list(folder: str = "") -> list:
    """Список заметок в Obsidian Vault (опционально по папке)."""
    if not os.path.isdir(VAULT_DIR):
        return [{"error": "Obsidian Vault не найден"}]

    target = os.path.join(VAULT_DIR, folder) if folder else VAULT_DIR
    notes = []

    for root, dirs, files in os.walk(target):
        for f in files:
            if f.endswith(".md"):
                full_path = os.path.join(root, f)
                notes.append({
                    "path": os.path.relpath(full_path, VAULT_DIR),
                    "size_kb": round(os.path.getsize(full_path) / 1024, 1),
                })

    return sorted(notes, key=lambda x: x["path"])


@mcp.tool()
def obsidian_write(note: str, content: str) -> str:
    """Создать или обновить заметку в Obsidian Vault."""
    if not os.path.isdir(VAULT_DIR):
        return "Obsidian Vault не найден"

    path = os.path.join(VAULT_DIR, note)
    if not path.endswith(".md"):
        path += ".md"

    os.makedirs(os.path.dirname(path), exist_ok=True)
    with open(path, "w") as f:
        f.write(content)

    return f"Заметка сохранена: {os.path.relpath(path, VAULT_DIR)}"


# ═══════════════════════════════════════════════════════════
# QUEUE — Очередь задач
# ═══════════════════════════════════════════════════════════

@mcp.tool()
def queue_status() -> dict:
    """Статус очереди задач."""
    files = os.listdir(QUEUE_DIR)
    pending = [f for f in files if f.endswith(".json")]
    res_files = os.listdir(RESULTS_DIR)
    completed = [f for f in res_files if f.endswith(".json")]

    return {
        "pending_count": len(pending),
        "completed_count": len(completed),
        "pending": pending[:10],
    }


@mcp.tool()
def queue_write(task_id: str, task_description: str, priority: int = 1) -> str:
    """Добавить задачу в очередь."""
    file_path = os.path.join(QUEUE_DIR, f"{task_id}.json")
    data = {
        "id": task_id,
        "task": task_description,
        "priority": priority,
        "status": "pending",
        "timestamp": datetime.now().isoformat(),
    }
    with open(file_path, "w") as f:
        json.dump(data, f, indent=2)
    return f"Задача {task_id} добавлена в очередь"


@mcp.tool()
def result_read(task_id: str) -> str:
    """Прочитать результат задачи."""
    for ext in [".json", ".txt"]:
        path = os.path.join(RESULTS_DIR, f"{task_id}{ext}")
        if os.path.exists(path):
            with open(path, "r") as f:
                return f.read()
    return f"Результат для {task_id} не найден"


# ═══════════════════════════════════════════════════════════
# SHELL — Выполнение команд
# ═══════════════════════════════════════════════════════════

@mcp.tool()
def smart_call(
    agent_type: str,
    task: str,
    agent_name: str = None,
    auto_context: bool = True,
) -> dict:
    """
    Умный вызов агента с АВТОМАТИЧЕСКИМ контекстом.

    agent_type: ollama | qwen_cli | gemini_cli | copilot | shell
    task: задача
    agent_name: имя для логов (авто если не указано)
    auto_context: True → автоматически инжектит контекст (экономит 1000-3000 токенов)

    Что делает:
      1. Классифицирует задачу
      2. Ищет контекст в AnythingLLM RAG
      3. Ищет прошлые похожие действия
      4. Ищет известные ошибки
      5. Формирует enriched prompt
      6. Вызывает агента
      7. Логирует результат
    """
    agent_name = agent_name or f"{agent_type}_auto"

    if auto_context:
        return call_agent_with_context(agent_type, task, agent_name)
    else:
        # Без контекста — прямой вызов (для совместимости)
        if agent_type == "ollama":
            return {"result": ollama_run(task)}
        elif agent_type == "qwen_cli":
            return {"result": qwen_run(task)}
        elif agent_type == "gemini_cli":
            return {"result": gemini_run(task)}
        elif agent_type == "copilot":
            return {"result": copilot_suggest(task)}
        elif agent_type == "shell":
            return {"result": shell_exec(task)}
        return {"error": f"Unknown agent: {agent_type}"}


# ═══════════════════════════════════════════════════════════
# SHELL — Выполнение команд
# ═══════════════════════════════════════════════════════════

@mcp.tool()
def shell_exec(command: str, cwd: str = PROJECT_ROOT, timeout: int = 300) -> str:
    """Выполнить shell-команду."""
    try:
        result = subprocess.run(
            command, shell=True, capture_output=True, text=True,
            cwd=cwd, timeout=timeout
        )
        return f"STDOUT:\n{result.stdout}\nSTDERR:\n{result.stderr}"
    except Exception as e:
        return f"Shell error: {str(e)}"


# ═══════════════════════════════════════════════════════════
# SYSTEM — Информация о системе
# ═══════════════════════════════════════════════════════════

@mcp.tool()
def system_info() -> dict:
    """Полная информация о системе: модели, агенты, ресурсы."""
    health = agent_health()
    models = MODEL_REGISTRY

    return {
        "system": "Multi-Agent Hub",
        "version": "2.0",
        "agents": health,
        "model_registry": {
            "local": list(models["local"].keys()),
            "cloud": list(models["cloud"].keys()),
            "async": list(models["async"].keys()),
            "on_demand": list(models["on_demand"].keys()),
        },
    }


if __name__ == "__main__":
    mcp.run()
