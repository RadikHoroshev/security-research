# ═══════════════════════════════════════════════════════════
# HEALTH CHECK — Проверка доступности агентов
# ═══════════════════════════════════════════════════════════

@mcp.tool()
def agent_health() -> dict:
    """Проверить статус ВСЕХ агентов системы. Возвращает health report."""
    agents = {}

    # Ollama (локальные модели)
    ollama_ok = False
    ollama_models = []
    try:
        r = subprocess.run(
            [AGENT_PATHS["ollama"], "list"],
            capture_output=True, text=True, timeout=10
        )
        if r.returncode == 0:
            ollama_ok = True
            for line in r.stdout.strip().split("\n")[1:]:
                if line.strip():
                    ollama_models.append(line.split()[0])
    except Exception as e:
        agents["ollama"] = {"status": "error", "detail": str(e)}

    agents["ollama"] = {
        "status": "online" if ollama_ok else "offline",
        "models": ollama_models,
        "type": "local",
        "limits": "none",
    }

    # Qwen CLI
    try:
        r = subprocess.run(
            [AGENT_PATHS["qwen_cli"], "--version"],
            capture_output=True, text=True, timeout=5
        )
        agents["qwen_cli"] = {
            "status": "online" if r.returncode == 0 else "offline",
            "version": r.stdout.strip() if r.returncode == 0 else "unknown",
            "type": "cloud_cli",
            "limits": "API limits apply",
        }
    except Exception as e:
        agents["qwen_cli"] = {"status": "error", "detail": str(e)}

    # Gemini CLI
    try:
        r = subprocess.run(
            [AGENT_PATHS["gemini_cli"], "--version"],
            capture_output=True, text=True, timeout=5
        )
        agents["gemini_cli"] = {
            "status": "online" if r.returncode == 0 else "offline",
            "version": r.stdout.strip() if r.returncode == 0 else "unknown",
            "type": "cloud_cli",
            "limits": "API limits apply",
        }
    except Exception as e:
        agents["gemini_cli"] = {"status": "error", "detail": str(e)}

    # Jules
    try:
        r = subprocess.run(
            [AGENT_PATHS["jules"], "--version"],
            capture_output=True, text=True, timeout=5
        )
        agents["jules"] = {
            "status": "online" if r.returncode == 0 else "offline",
            "type": "async",
            "limits": "API limits apply",
        }
    except Exception as e:
        agents["jules"] = {"status": "error", "detail": str(e)}

    # Codex CLI
    try:
        r = subprocess.run(
            [AGENT_PATHS["codex"], "--version"],
            capture_output=True, text=True, timeout=5
        )
        agents["codex"] = {
            "status": "online" if r.returncode == 0 else "offline",
            "type": "on_demand",
            "limits": "OpenAI API limits",
        }
    except Exception as e:
        agents["codex"] = {"status": "error", "detail": str(e)}

    # Copilot CLI
    try:
        r = subprocess.run(
            [AGENT_PATHS["copilot"], "--version"],
            capture_output=True, text=True, timeout=5
        )
        agents["copilot"] = {
            "status": "online" if r.returncode == 0 else "offline",
            "version": r.stdout.strip() if r.returncode == 0 else "unknown",
            "type": "shell_expert",
            "limits": "GitHub Copilot subscription",
        }
    except Exception as e:
        agents["copilot"] = {"status": "error", "detail": str(e)}

    # Claude Desktop
    claude_path = "/Applications/Claude.app"
    agents["claude_desktop"] = {
        "status": "installed" if os.path.exists(claude_path) else "not_installed",
        "type": "on_demand",
        "limits": "API limits apply",
    }

    # Obsidian Vault
    agents["obsidian"] = {
        "status": "available" if os.path.isdir(VAULT_DIR) else "not_found",
        "type": "knowledge",
        "path": VAULT_DIR,
    }

    # AnythingLLM
    anythingllm_path = os.path.expanduser(
        "~/Library/Application Support/anythingllm-desktop"
    )
    agents["anythingllm"] = {
        "status": "installed" if os.path.isdir(anythingllm_path) else "not_found",
        "type": "rag",
    }

    return agents


# ═══════════════════════════════════════════════════════════
# SMART ROUTER — Маршрутизация с fallback
# ═══════════════════════════════════════════════════════════

@mcp.tool()
def route_task(
    task_type: str,
    prompt: str,
    model: str = "auto",
    priority: str = "normal",
) -> dict:
    """
    Умная маршрутизация задачи к лучшему агенту.

    task_type: coding | reasoning | general | review | heavy | async
    model: 'auto' для автоматического выбора, или конкретная модель
    priority: low | normal | high

    Fallback chain:
      1. Локальные Ollama модели (бесплатно, без лимитов)
      2. Облачные CLI (Qwen, Gemini)
      3. Асинхронные (Jules)
      4. On-demand (Codex, Claude Desktop)
    """
    task_type = task_type.lower()
    model = model.lower() if model != "auto" else model

    # Определяем лучшего агента
    if model == "auto":
        if task_type == "coding":
            # Приоритет: локальная 14b → 7b → Qwen CLI
            agent, m = _first_available([
                ("ollama", "qwen2.5-coder:14b"),
                ("ollama", "qwen2.5-coder:7b"),
                ("qwen_cli", None),
            ])
        elif task_type == "reasoning":
            # Приоритет: deepseek → Qwen CLI → Gemini CLI
            agent, m = _first_available([
                ("ollama", "deepseek-r1:8b"),
                ("qwen_cli", None),
                ("gemini_cli", None),
            ])
        elif task_type == "general":
            # Приоритет: gemma4 → Gemini CLI → Qwen CLI
            agent, m = _first_available([
                ("ollama", "gemma4:latest"),
                ("gemini_cli", None),
                ("ollama", "qwen2.5-coder:7b"),
            ])
        elif task_type == "review":
            # Приоритет: Qwen 14b → Codex → Gemini
            agent, m = _first_available([
                ("ollama", "qwen2.5-coder:14b"),
                ("codex", None),
                ("gemini_cli", None),
            ])
        elif task_type == "heavy":
            # Приоритет: Qwen CLI → Claude Desktop → Jules async
            agent, m = _first_available([
                ("qwen_cli", None),
                ("claude_desktop", None),
                ("jules", None),
            ])
        elif task_type == "async":
            # Всегда Jules
            agent, m = "jules", None
        else:
            agent, m = "ollama", "qwen2.5-coder:14b"
    else:
        # Ручной выбор модели
        agent, m = _resolve_model(model)

    return {
        "task_type": task_type,
        "assigned_agent": agent,
        "model": m,
        "priority": priority,
        "prompt": prompt,
        "status": "routed",
    }


def _first_available(options: list) -> tuple:
    """Найти первый доступный агент из списка."""
    health = agent_health()

    for agent_key, model in options:
        if agent_key == "ollama":
            if health.get("ollama", {}).get("status") == "online":
                if model in health["ollama"].get("models", []):
                    return "ollama", model
        elif agent_key in health:
            if health[agent_key].get("status") == "online":
                return agent_key, model

    # Fallback на последний вариант
    return options[-1] if options else ("ollama", "qwen2.5-coder:7b")


def _resolve_model(model: str) -> tuple:
    """Разрешить имя модели в (agent, model_name)."""
    for tier in MODEL_REGISTRY.values():
        if model in tier:
            info = tier[model]
            return model, info.get("model", model)
    # По умолчанию — локальная
    return "ollama", model


# ═══════════════════════════════════════════════════════════
# АГЕНТЫ — Прямые вызовы
# ═══════════════════════════════════════════════════════════

@mcp.tool()
def ollama_run(prompt: str, model: str = "qwen2.5-coder:14b", timeout: int = 120) -> str:
    """Запустить запрос через локальную Ollama модель. Бесплатно, без лимитов."""
    try:
        cmd = [AGENT_PATHS["ollama"], "run", model, prompt]
        result = subprocess.run(cmd, capture_output=True, text=True, timeout=timeout)
        if result.returncode == 0:
            return result.stdout.strip()
        return f"Error: {result.stderr}"
    except subprocess.TimeoutExpired:
        return f"Timeout ({timeout}s) — fallback recommended"
    except Exception as e:
        return f"Exception: {str(e)}"


@mcp.tool()
def qwen_run(prompt: str, timeout: int = 300) -> str:
    """Запустить запрос через Qwen CLI."""
    try:
        cmd = [AGENT_PATHS["qwen_cli"], "--prompt", prompt]
        result = subprocess.run(cmd, capture_output=True, text=True, timeout=timeout)
        if result.returncode == 0:
            return result.stdout.strip()
        return f"Error: {result.stderr}"
    except subprocess.TimeoutExpired:
        return f"Timeout ({timeout}s) — возможно исчерпан лимит"
    except Exception as e:
        return f"Exception: {str(e)}"


