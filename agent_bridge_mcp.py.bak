@mcp.tool()
def copilot_suggest(description: str, timeout: int = 60) -> str:
    """Предложить shell-команду по описанию (Copilot CLI, gpt-5-mini)."""
    try:
        cmd = [
            AGENT_PATHS["copilot"], "-p", description,
            "--model", AGENT_PATHS["copilot_model"],
            "--allow-all", "--allow-all-tools", "--allow-all-urls",
        ]
        result = subprocess.run(cmd, capture_output=True, text=True, timeout=timeout)
        if result.returncode == 0:
            return result.stdout.strip()
        return f"Error: {result.stderr}"
    except subprocess.TimeoutExpired:
        return f"Timeout ({timeout}s) — Copilot долго думает"
    except Exception as e:
        return f"Exception: {str(e)}"


